# ─── 데이터베이스 ─────────────────────────────────────────────────────────────
# PostgreSQL 연결 문자열 (Neon, Railway, Supabase 등)
DATABASE_URL=postgresql://user:password@host:5432/contentpilot

# ─── 세션 ─────────────────────────────────────────────────────────────────────
SESSION_SECRET=your-very-long-random-secret-key-here

# ─── Google OAuth 2.0 인증 ───────────────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials 에서 OAuth 2.0 클라이언트 생성
# 승인된 리디렉션 URI: https://your-domain.com/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://your-domain.com/api/auth/google/callback

# ─── AI API 키 ────────────────────────────────────────────────────────────────
# OpenAI (텍스트 생성: 인스타그램 슬라이드, 블로그, 발명 아이디어 등)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Google Gemini (이미지 생성)
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# ─── 앱 설정 ─────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
# 배포 도메인 (Instagram 이미지 임시 서빙용)
APP_BASE_URL=https://your-domain.com

# ─── TTS (선택사항) ───────────────────────────────────────────────────────────
# CLOVA Voice (네이버 클로바)
# CLOVA_CLIENT_ID=
# CLOVA_CLIENT_SECRET=

# ElevenLabs
# ELEVENLABS_API_KEY=

# Fish Audio
# FISH_AUDIO_API_KEY=

# ─── 플랫폼 연결은 앱 내 설정 페이지에서 진행합니다 ─────────────────────────
# Instagram, WordPress, Tistory 연결 정보는 DB에 암호화 저장됩니다.
